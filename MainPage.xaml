<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TCP_Messages.MainPage"
             Title="TCP Controller">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">

            <VerticalStackLayout x:Name="ButtonsContainer" Spacing="10" Margin="0,10,0,0" />

            <Button Text="+" 
        Clicked="OnTogglePanelClicked"
        FontSize="24"
        HeightRequest="50"
        WidthRequest="50"
        HorizontalOptions="Center"
        BackgroundColor="#512BD4"
        TextColor="White" 
        Margin="20"
        />

            <Border x:Name="InputPanel"
        IsVisible="False"
        Stroke="{StaticResource Primary}"
        StrokeThickness="1"
        Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Nuovo Comando" FontAttributes="Bold" FontSize="18" />
                    <Entry x:Name="LabelEntry" Placeholder="Etichetta Bottone" />
                    <Entry x:Name="IpEntry" Placeholder="IP Server" Keyboard="Plain" />
                    <Entry x:Name="PortEntry" Placeholder="Porta" Keyboard="Numeric" />
                    <Entry x:Name="CommandEntry" Placeholder="Comando TCP" />

                    <Button Text="SALVA" 
                Clicked="OnAddButtonClicked" 
                BackgroundColor="{StaticResource Primary}" 
                TextColor="White" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>